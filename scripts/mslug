#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNNER="$ROOT/scripts/run_mslug_sdl.sh"
HOST_BIN="$ROOT/build/mslug_sdl_host"
DEFAULT_GAME="$HOME/Documents/Games/Mister/NEOGEO/mslug.neo"
DEFAULT_BIOS="$HOME/Documents/Games/Mister/NEOGEO/bios/sp-s2.sp1"
REBUILD=0
: "${NG_MSLUG_SDL_FAST_FORWARD:=0}"
export NG_MSLUG_SDL_FAST_FORWARD

usage() {
  cat >&2 <<USAGE
usage: scripts/mslug [quick|attract|rebuild|build|--ff N|--dpf N|--diag N|--perf-log|--present-mode frame|video|slice|--video-settle N|--frame-hold N|--palette-bank active|auto|0|1|--watchdog-cycles N|--start-bios] [game.neo bios.rom [lo-rom]]

Default paths:
  ~/Documents/Games/Mister/NEOGEO/mslug.neo
  ~/Documents/Games/Mister/NEOGEO/bios/sp-s2.sp1

Examples:
  scripts/mslug            # launch cached host only, no pre-window fast-forward
  scripts/mslug quick      # cached launch with 10k pre-window fast-forward
  scripts/mslug build      # expensive build/relink only
  scripts/mslug rebuild    # force build/relink, then launch
  scripts/mslug attract    # cached launch with deeper 500k fast-forward
USAGE
}

is_build_only() {
  [[ "${NG_MSLUG_SDL_BUILD_ONLY:-0}" != "0" ]]
}

launch_cached_host() {
  if (($# > 3)); then
    usage
    exit 2
  fi

  local game="${1:-$DEFAULT_GAME}"
  local bios="${2:-$DEFAULT_BIOS}"
  local lo_rom="${3:-}"
  local fast_forward="${NG_MSLUG_SDL_FAST_FORWARD:-0}"
  local dpf="${NG_MSLUG_SDL_DISPATCHES_PER_REFRESH:-50000}"
  local present_mode="${NG_MSLUG_SDL_PRESENT_MODE:-frame}"
  local palette_bank="${NG_MSLUG_SDL_PALETTE_BANK:-active}"
  local scanline_poll="${NG_MSLUG_SCANLINE_POLL_INTERVAL:-0}"
  local watchdog_timeout_cycles="${NG_MSLUG_WATCHDOG_TIMEOUT_CYCLES:-}"
  local watchdog_timeout_polls="${NG_MSLUG_WATCHDOG_TIMEOUT_POLLS:-}"
  local video_settle="${NG_MSLUG_SDL_VIDEO_SETTLE_DISPATCHES:-16}"
  local frame_hold="${NG_MSLUG_SDL_FRAME_HOLD:-1}"
  local start_mode="${NG_MSLUG_START_MODE:-cart}"
  local scale="${NG_MSLUG_SDL_SCALE:-3}"
  local max_refreshes="${NG_MSLUG_SDL_MAX_REFRESHES:-}"
  local status_interval="${NG_MSLUG_SDL_STATUS_INTERVAL:-}"
  local diagnostics_interval="${NG_MSLUG_SDL_DIAGNOSTICS_INTERVAL:-}"
  local perf_log="${NG_MSLUG_SDL_PERF_LOG:-0}"
  local dump_state_dir="${NG_MSLUG_SDL_DUMP_STATE_DIR:-}"
  local stall_refreshes="${NG_MSLUG_SDL_STALL_REFRESHES:-}"
  local no_throttle="${NG_MSLUG_SDL_NO_THROTTLE:-0}"

  if [[ ! -x "$HOST_BIN" ]]; then
    echo "cached host missing: $HOST_BIN" >&2
    echo "run first: scripts/mslug build" >&2
    exit 2
  fi
  if [[ ! -f "$game" ]]; then
    echo "mslug .neo not found: $game" >&2
    exit 2
  fi
  if [[ ! -f "$bios" ]]; then
    echo "BIOS not found: $bios" >&2
    exit 2
  fi

  local host_args=(
    --fast-forward "$fast_forward"
    --dispatches-per-refresh "$dpf"
    --present-mode "$present_mode"
    --palette-bank "$palette_bank"
    --scanline-poll-interval "$scanline_poll"
    --video-settle-dispatches "$video_settle"
    --frame-hold "$frame_hold"
    --scale "$scale"
  )
  if [[ -n "$max_refreshes" ]]; then
    host_args+=(--max-refreshes "$max_refreshes")
  fi
  if [[ -n "$status_interval" ]]; then
    host_args+=(--status-interval "$status_interval")
  fi
  if [[ -n "$diagnostics_interval" ]]; then
    host_args+=(--diagnostics-interval "$diagnostics_interval")
  fi
  if [[ "$perf_log" != "0" ]]; then
    host_args+=(--perf-log)
  fi
  if [[ -n "$dump_state_dir" ]]; then
    mkdir -p "$dump_state_dir"
    host_args+=(--dump-state-dir "$dump_state_dir")
  fi
  if [[ -n "$stall_refreshes" ]]; then
    host_args+=(--stall-refreshes "$stall_refreshes")
  fi
  if [[ "$no_throttle" != "0" ]]; then
    host_args+=(--no-throttle)
  fi
  if [[ -n "$watchdog_timeout_cycles" ]]; then
    host_args+=(--watchdog-timeout-cycles "$watchdog_timeout_cycles")
  fi
  if [[ -n "$watchdog_timeout_polls" ]]; then
    host_args+=(--watchdog-timeout-polls "$watchdog_timeout_polls")
  fi
  if [[ "$start_mode" == "bios" ]]; then
    host_args+=(--start-bios)
  fi
  host_args+=("$game" "$bios")
  if [[ -n "$lo_rom" ]]; then
    host_args+=("$lo_rom")
  fi

  printf '==> Launching cached Metal Slug host\n' >&2
  printf '    fast-forward: %s dispatches\n' "$fast_forward" >&2
  printf '    safety dispatch cap/refresh: %s\n' "$dpf" >&2
  printf '    present mode: %s\n' "$present_mode" >&2
  printf '    frame hold: %s\n' "$frame_hold" >&2
  printf '    palette bank: %s\n' "$palette_bank" >&2
  exec "$HOST_BIN" "${host_args[@]}"
}

declare -a args=()
while (($#)); do
  case "$1" in
    quick|--quick|-q)
      export NG_MSLUG_SDL_FAST_FORWARD=10000
      ;;
    attract|--attract)
      export NG_MSLUG_SDL_FAST_FORWARD=500000
      ;;
    noff|--no-ff)
      export NG_MSLUG_SDL_FAST_FORWARD=0
      ;;
    rebuild|--rebuild)
      REBUILD=1
      ;;
    build|--build|--build-only)
      REBUILD=1
      export NG_MSLUG_SDL_BUILD_ONLY=1
      ;;
    --ff)
      shift
      if (($# == 0)); then
        echo "--ff needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_FAST_FORWARD="$1"
      ;;
    --scale)
      shift
      if (($# == 0)); then
        echo "--scale needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_SCALE="$1"
      ;;
    --dpf)
      shift
      if (($# == 0)); then
        echo "--dpf needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_DISPATCHES_PER_REFRESH="$1"
      ;;
    --present-mode)
      shift
      if (($# == 0)); then
        echo "--present-mode needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_PRESENT_MODE="$1"
      ;;
    --present-frame|--frame-sync)
      export NG_MSLUG_SDL_PRESENT_MODE=frame
      ;;
    --present-video|--video-sync)
      export NG_MSLUG_SDL_PRESENT_MODE=video
      ;;
    --present-slice|--slice)
      export NG_MSLUG_SDL_PRESENT_MODE=slice
      ;;
    --palette-bank)
      shift
      if (($# == 0)); then
        echo "--palette-bank needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_PALETTE_BANK="$1"
      ;;
    --diag|--diagnostics-interval)
      shift
      if (($# == 0)); then
        echo "--diag needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_DIAGNOSTICS_INTERVAL="$1"
      ;;
    --perf-log)
      export NG_MSLUG_SDL_PERF_LOG=1
      ;;
    --watchdog-cycles|--watchdog-timeout-cycles)
      shift
      if (($# == 0)); then
        echo "--watchdog-cycles needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_WATCHDOG_TIMEOUT_CYCLES="$1"
      ;;
    --watchdog|--watchdog-timeout-polls)
      shift
      if (($# == 0)); then
        echo "--watchdog needs a value" >&2
        usage
        exit 2
      fi
      echo "warning: --watchdog is legacy poll-based; use --watchdog-cycles for cycle timing" >&2
      export NG_MSLUG_WATCHDOG_TIMEOUT_CYCLES=0
      export NG_MSLUG_WATCHDOG_TIMEOUT_POLLS="$1"
      ;;
    --video-settle|--video-settle-dispatches)
      shift
      if (($# == 0)); then
        echo "--video-settle needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_VIDEO_SETTLE_DISPATCHES="$1"
      ;;
    --frame-hold|--hold|--slowmo)
      shift
      if (($# == 0)); then
        echo "--frame-hold needs a value" >&2
        usage
        exit 2
      fi
      export NG_MSLUG_SDL_FRAME_HOLD="$1"
      ;;
    --start-bios)
      export NG_MSLUG_START_MODE=bios
      ;;
    --start-cart)
      export NG_MSLUG_START_MODE=cart
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift
done

# The user-facing command should feel like "play": no hidden recompilation.
# Use `scripts/mslug build` for the expensive generated-code pipeline, then
# `scripts/mslug` for sub-second cached launches.
if ((! REBUILD)) && ! is_build_only; then
  if ((${#args[@]})); then
    launch_cached_host "${args[@]}"
  else
    launch_cached_host
  fi
fi

if ((${#args[@]})); then
  exec "$RUNNER" "${args[@]}"
else
  exec "$RUNNER"
fi
